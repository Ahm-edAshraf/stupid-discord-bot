# Copy to `.env` and fill in values (never commit real secrets).
DISCORD_TOKEN=YOUR_DISCORD_TOKEN

# Optional: if set, slash commands sync to this guild for faster iteration.
# DISCORD_GUILD_ID=123456789012345678

# Optional: fastest dev mode.
# If set to 1, the bot copies/syncs slash commands to every guild it is currently in on startup.
# DISCORD_SYNC_ALL_GUILDS=1

